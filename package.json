{
  "name": "rate-my-day",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:validate": "prisma validate",
    "scripts:check": "tsc -p tsconfig.scripts.json --noEmit",
    "check": "npm run lint && npm run prisma:validate && npm run build",
    "check:full": "npm run lint && npm run prisma:validate && npm run build && npm run scripts:check",
    "audit:prod": "npm audit --omit=dev",
    "audit:signatures": "npm audit signatures",
    "release:check": "npm run check:full && npm run audit:signatures && npm run audit:prod"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "he": "^1.2.0",
    "html-to-image": "^1.11.13",
    "next": "^16.2.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/he": "^1.2.3",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.8",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5"
  }
}
