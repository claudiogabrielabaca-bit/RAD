generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  username     String  @unique
  passwordHash String
  bio          String?

  emailVerified        Boolean   @default(false)
  emailVerifyCode      String?
  emailVerifyExpiresAt DateTime?
  emailVerifyAttempts  Int       @default(0)

  loginCode          String?
  loginCodeExpiresAt DateTime?
  loginCodeAttempts  Int       @default(0)

  passwordResetCode      String?
  passwordResetExpiresAt DateTime?
  passwordResetAttempts  Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions              Session[]
  ratings               Rating[]
  likes                 RatingLike[]
  reports               ReviewReport[]
  replies               RatingReply[]
  replyLikes            ReplyLike[]
  replyReports          ReplyReport[]
  favoriteDays          FavoriteDay[]
  surpriseDecks         SurpriseDeck[]
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsSent     Notification[] @relation("NotificationActor")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model AdminSession {
  id        String   @id @default(cuid())
  username  String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

model Rating {
  id        String   @id @default(cuid())
  anonId    String?
  userId    String?
  day       String
  stars     Int
  review    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  likes         RatingLike[]
  reports       ReviewReport[]
  replies       RatingReply[]
  notifications Notification[]

  @@unique([anonId, day], name: "anonId_day")
  @@unique([userId, day], name: "userId_day")
  @@index([day, createdAt], name: "rating_day_created_at_idx")
  @@index([day, stars], name: "rating_day_stars_idx")
}

model RatingLike {
  id        String   @id @default(cuid())
  ratingId  String
  anonId    String?
  userId    String?
  createdAt DateTime @default(now())

  rating Rating @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ratingId, anonId], name: "rating_like_anon_unique")
  @@unique([ratingId, userId], name: "rating_like_user_unique")
}

model ReviewReport {
  id        String   @id @default(cuid())
  ratingId  String
  anonId    String?
  userId    String?
  reason    String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rating Rating @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ratingId, anonId], name: "review_report_anon_unique")
  @@unique([ratingId, userId], name: "review_report_user_unique")
}

model RatingReply {
  id            String   @id @default(cuid())
  ratingId      String
  anonId        String?
  userId        String?
  parentReplyId String?
  text          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rating        Rating         @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentReply   RatingReply?   @relation("ReplyThread", fields: [parentReplyId], references: [id], onDelete: Cascade)
  childReplies  RatingReply[]  @relation("ReplyThread")
  likes         ReplyLike[]
  reports       ReplyReport[]
  notifications Notification[]

  @@index([ratingId])
  @@index([ratingId, createdAt], name: "rating_reply_rating_created_at_idx")
  @@index([parentReplyId])
}

model ReplyLike {
  id        String   @id @default(cuid())
  replyId   String
  anonId    String?
  userId    String?
  createdAt DateTime @default(now())

  reply RatingReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user  User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([replyId, anonId], name: "reply_like_anon_unique")
  @@unique([replyId, userId], name: "reply_like_user_unique")
  @@index([replyId])
}

model ReplyReport {
  id        String   @id @default(cuid())
  replyId   String
  anonId    String?
  userId    String?
  reason    String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reply RatingReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user  User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([replyId, anonId], name: "reply_report_anon_unique")
  @@unique([replyId, userId], name: "reply_report_user_unique")
  @@index([replyId])
}

model FavoriteDay {
  id        String   @id @default(cuid())
  anonId    String?
  userId    String?
  day       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([anonId, day], name: "favorite_day_anon_unique")
  @@unique([userId, day], name: "favorite_day_user_unique")
}

model DayHighlightCache {
  id         String   @id @default(cuid())
  day        String   @unique
  type       String
  year       Int?
  title      String?
  text       String
  image      String?
  articleUrl String?
  highlights Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PickDateCache {
  day          String    @id
  status       String
  type         String
  year         Int
  month        Int       @default(0)
  monthDay     String    @default("")
  decade       Int       @default(0)
  century      Int       @default(0)
  title        String?
  text         String?
  image        String?
  articleUrl   String?
  highlights   Json?
  source       String    @default("v1-pick-date-cache")
  qualityScore Int       @default(0)
  attempts     Int       @default(0)
  lastError    String?
  generatedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([source])
  @@index([year])
  @@index([month])
  @@index([monthDay])
  @@index([decade])
  @@index([century])
  @@index([generatedAt])
}

model SurprisePoolDay {
  id           String   @id @default(cuid())
  day          String   @unique
  year         Int
  month        Int
  dayOfMonth   Int
  monthDay     String
  decade       Int
  century      Int
  type         String
  title        String
  text         String
  image        String?
  articleUrl   String?
  source       String   @default("day_highlight_cache")
  qualityScore Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active])
  @@index([active, month])
  @@index([active, monthDay])
  @@index([active, decade])
  @@index([active, century])
  @@index([active, type])
}

model DayStats {
  id        String   @id @default(cuid())
  day       String   @unique
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DayRatingAggregate {
  day          String   @id
  ratingsCount Int      @default(0)
  starsSum     Int      @default(0)
  avgStars     Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([ratingsCount, avgStars], name: "day_rating_aggregate_top_idx")
  @@index([avgStars, ratingsCount], name: "day_rating_aggregate_avg_count_idx")
}

model RateLimit {
  id        String   @id @default(cuid())
  action    String
  key       String
  count     Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([action, key])
  @@index([expiresAt])
}

model SurpriseDeck {
  id            String   @id @default(cuid())
  ownerKey      String   @unique
  userId        String?
  deck          Json
  cursor        Int      @default(0)
  poolSize      Int
  poolSignature String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TodayHistoryPool {
  monthDay   String   @id
  validDays  Json
  validCount Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  actorUserId String
  type        NotificationType
  reviewId    String?
  replyId     String?
  day         String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user      User         @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actorUser User         @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  review    Rating?      @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reply     RatingReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead, createdAt])
  @@index([reviewId])
  @@index([replyId])
}

enum NotificationType {
  review_liked
  review_replied
  reply_liked
}
