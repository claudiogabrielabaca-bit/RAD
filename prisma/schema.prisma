generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Rating {
  id        String         @id @default(cuid())
  anonId    String
  day       String
  stars     Int
  review    String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  likes     RatingLike[]
  reports   ReviewReport[]
  replies   RatingReply[]

  @@unique([anonId, day], name: "anonId_day")
}

model RatingLike {
  id        String   @id @default(cuid())
  ratingId  String
  anonId    String
  createdAt DateTime @default(now())

  rating Rating @relation(fields: [ratingId], references: [id], onDelete: Cascade)

  @@unique([ratingId, anonId], name: "rating_like_unique")
}

model ReviewReport {
  id        String   @id @default(cuid())
  ratingId  String
  anonId    String
  reason    String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rating Rating @relation(fields: [ratingId], references: [id], onDelete: Cascade)

  @@unique([ratingId, anonId], name: "review_report_unique")
}

model RatingReply {
  id        String   @id @default(cuid())
  ratingId  String
  anonId    String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rating Rating @relation(fields: [ratingId], references: [id], onDelete: Cascade)
}

model DayHighlightCache {
  id         String   @id @default(cuid())
  day        String   @unique
  type       String
  year       Int?
  title      String?
  text       String
  image      String?
  articleUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DayStats {
  id        String   @id @default(cuid())
  day       String   @unique
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}